# Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# Cloudinary (Images only, signed uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET

# Single city (MVP)
NEXT_PUBLIC_CITY_ID=dharamshala
NEXT_PUBLIC_CITY_LABEL=Dharamshala

# Support / contact
# Used for footer contact info and mailto: links.
NEXT_PUBLIC_CONTACT_EMAIL=vstudent343@gmail.com

# Site URL (optional)
# Used for sitemap/robots URLs. If not set, Vercel deployments fall back to VERCEL_URL, otherwise https://vstudent.in
NEXT_PUBLIC_SITE_URL=https://vstudent.in

# Institution labels (optional)
# Used for UI text like “Walking distance to …” and “Share to … WhatsApp group”.
NEXT_PUBLIC_PRIMARY_INSTITUTION_SHORT=GCD
NEXT_PUBLIC_PRIMARY_INSTITUTION_LONG=Govt College Dharamshala (GCD)

# Moderation (optional)
# Set to 1 to require admin approval before listing is public.
NEXT_PUBLIC_REQUIRE_APPROVAL=0
