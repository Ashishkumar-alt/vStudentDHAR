rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow delete: if false;

      match /favorites/{favId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    function listingReadable(resource) {
      return resource.data.status == "active" || 
             isAdmin() || 
             (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    function canReadRoom(resource) {
      // Public room pages must stay readable for active listings even when request.auth is null.
      return resource.data.status == "active" ||
        isAdmin() ||
        (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    function canCreateListing() {
      return isSignedIn();
    }

    function listingCreatable() {
      return isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    function listingUpdatable(resource) {
      return isAdmin() ||
        (isSignedIn()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.status == resource.data.status);
    }

    match /rooms/{id} {
      // Active room listings are public; writes still require auth/admin checks below.
      allow read: if canReadRoom(resource);
      allow create: if canCreateListing() && listingCreatable();
      allow update: if listingUpdatable(resource);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /rooms/{id}/views/{viewerId} {
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/rooms/$(id)).data.createdBy == request.auth.uid);
      allow create, update: if isSignedIn() && request.auth.uid == viewerId;
      allow delete: if false;
    }

    match /items/{id} {
      allow read: if listingReadable(resource);
      allow create: if listingCreatable();
      allow update: if listingUpdatable(resource);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /items/{id}/views/{viewerId} {
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/items/$(id)).data.createdBy == request.auth.uid);
      allow create, update: if isSignedIn() && request.auth.uid == viewerId;
      allow delete: if false;
    }

    match /reports/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "open";
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /admin_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }
  }
}
